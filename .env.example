# =============================================================================
# Technology Pipeline Tracker — Environment Variables
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
# Never commit .env to git — it is listed in .gitignore.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — the system will not start without these
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic — Claude API (analyst agent reasoning + self-critique)
# How to get: https://console.anthropic.com/ → API Keys → Create Key
# Accepts either name:
ANTHROPIC_KEY=
# ANTHROPIC_API_KEY=      # alternative name also accepted

# GitHub — repository search (Stage 2: Developer signals)
# How to get: https://github.com/settings/tokens → Generate new token (classic)
# Scope needed: public_repo (read-only)
GITHUB_TOKEN=

# Product Hunt — product launch search (Stage 2: Startup signals)
# How to get: https://www.producthunt.com/v2/oauth/applications → New application
# Use either a developer access token OR the client ID + secret pair:
PRODUCTHUNT_ACCESS_TOKEN=
# --- OR ---
PRODUCTHUNT_CLIENT_ID=
PRODUCTHUNT_CLIENT_SECRET=

# NewsAPI — investment/funding news (Stage 3: Investment signals)
# How to get: https://newsapi.org/register  (free tier: 100 req/day)
NEWS_API_KEY=

# Neo4j — knowledge graph (GraphRAG relationship store)
# Local Docker:  bolt://localhost:7687
# Neo4j Aura:    neo4j+s://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# MongoDB — raw document store (all pipeline data)
# Local Docker:  mongodb://localhost:27017
# Atlas:         mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/
MONGO_URI=mongodb://localhost:27017


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — system works without these; rate limits or quality are lower
# ─────────────────────────────────────────────────────────────────────────────

# Semantic Scholar — academic paper search with citation counts (Stage 1)
# Without key: ~100 req / 5 min (shared pool)
# With key:    1 req / second (dedicated quota)
# How to get: https://www.semanticscholar.org/product/api → Request API Key
S2_API_KEY=

# Reddit — community discussion signals (supplementary)
# How to get: https://www.reddit.com/prefs/apps → Create app → script
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TechPipelineTracker/1.0 by u/yourusername


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE PATHS — defaults shown; override only if you need a custom location
# ─────────────────────────────────────────────────────────────────────────────

# ChromaDB vector store (sentence-transformer embeddings for RAG)
CHROMA_DB_PATH=database/chroma_db

# SQLite structured scores + timeline + query audit log
SQLITE_DB_PATH=database/pipeline_tracker.db


# ─────────────────────────────────────────────────────────────────────────────
# NO KEY NEEDED — these APIs are fully public, zero setup required
# ─────────────────────────────────────────────────────────────────────────────
# arXiv            tools/arxiv_tool.py        — Atom feed, no auth
# PatentsView      tools/patents_tool.py      — REST API, no auth
# Wikipedia        tools/wikipedia_tool.py    — MediaWiki + Pageviews, no auth
# Google Trends    tools/trends_tool.py       — trendspyg RSS, no auth
# TechCrunch       scrapers/techcrunch_scraper.py — HTML scraper, no auth
# YC Companies     scrapers/yc_scraper.py         — HTML scraper, no auth
